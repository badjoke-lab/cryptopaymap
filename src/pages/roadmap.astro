---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const sectionOrder = ['now', 'next', 'later', 'exploring'];
const sectionLabels = {
  now: 'Now',
  next: 'Next',
  later: 'Later',
  exploring: 'Exploring',
};
const sectionDescriptions = {
  now: 'Capabilities currently being established or validated.',
  next: 'Accepted capabilities that follow the current foundation.',
  later: 'Planned capabilities that depend on earlier product layers.',
  exploring: 'Ideas under consideration, not implementation commitments.',
};
const statusLabels = {
  in_progress: 'In progress',
  planned: 'Planned',
  completed: 'Completed',
  under_consideration: 'Under consideration',
  revised: 'Revised',
};

const roadmapEntries = (await getCollection('roadmap')).sort(
  (left, right) => left.data.order - right.data.order,
);
---

<BaseLayout
  title="Roadmap · CryptoPayMap"
  description="Public capability roadmap for CryptoPayMap."
>
  <div class="safe-area-inline page-container py-12 sm:py-16 lg:py-20">
    <header class="max-w-3xl">
      <p class="m-0 text-sm font-semibold uppercase tracking-[0.12em] text-brand-700">
        Public product roadmap
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-ink sm:text-5xl">
        What CryptoPayMap is building
      </h1>
      <p class="mt-5 text-lg leading-8 text-muted">
        This roadmap describes user-facing capabilities. Dataset counts belong in Stats, public
        record changes belong in Updates, and released product changes belong in Changelog.
      </p>
    </header>

    <div class="mt-12 grid gap-14 lg:mt-16">
      {
        sectionOrder.map((section) => {
          const entries = roadmapEntries.filter((entry) => entry.data.section === section);
          if (entries.length === 0) return null;

          return (
            <section aria-labelledby={`roadmap-${section}`} class="grid gap-6">
              <header class="max-w-3xl">
                <h2 id={`roadmap-${section}`} class="m-0 text-3xl font-semibold tracking-tight text-ink">
                  {sectionLabels[section]}
                </h2>
                <p class="mt-2 text-base leading-7 text-muted">{sectionDescriptions[section]}</p>
              </header>

              <div class="grid gap-5 lg:grid-cols-2">
                {entries.map((entry) => (
                  <article class="rounded-card border border-border bg-surface p-5 shadow-panel sm:p-6">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <h3 class="m-0 text-xl font-semibold tracking-tight text-ink">{entry.data.title}</h3>
                      <span class="rounded-pill bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-800">
                        {statusLabels[entry.data.status] ?? entry.data.status}
                      </span>
                    </div>

                    <p class="mt-4 text-base leading-7 text-muted">{entry.data.outcome}</p>

                    {entry.data.includes.length > 0 ? (
                      <div class="mt-5">
                        <h4 class="m-0 text-sm font-semibold text-ink">Includes</h4>
                        <ul class="mt-2 grid list-disc gap-2 pl-5 text-sm leading-6 text-muted">
                          {entry.data.includes.map((item) => <li>{item}</li>)}
                        </ul>
                      </div>
                    ) : null}

                    {entry.data.dependsOn.length > 0 ? (
                      <div class="mt-5">
                        <h4 class="m-0 text-sm font-semibold text-ink">Depends on</h4>
                        <ul class="mt-2 grid list-disc gap-2 pl-5 text-sm leading-6 text-muted">
                          {entry.data.dependsOn.map((item) => <li>{item}</li>)}
                        </ul>
                      </div>
                    ) : null}

                    <footer class="mt-6 border-t border-border pt-4 text-xs text-muted">
                      Last updated {entry.data.lastUpdated}
                    </footer>
                  </article>
                ))}
              </div>
            </section>
          );
        })
      }
    </div>

    <aside class="mt-14 rounded-card border border-border bg-brand-50 p-5 text-sm leading-6 text-ink sm:p-6">
      Roadmap items are not removed silently. Completed items link to a released Changelog version;
      revised or discontinued plans receive a public explanation.
    </aside>
  </div>
</BaseLayout>
