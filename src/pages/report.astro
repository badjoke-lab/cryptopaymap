---
import ContributionRoutePlaceholder from '../components/public/ContributionRoutePlaceholder.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Report a problem | CryptoPayMap"
  description="Status of the future CryptoPayMap public-record problem reporting workflow."
>
  <ContributionRoutePlaceholder
    eyebrow="Problem report"
    title="Report a problem"
    description="This route is reserved for reporting closure, ended acceptance, payment failure, incorrect payment details, wrong addresses, duplicate records, media-rights issues, privacy issues, and other public-record problems."
    futureCapability="The future workflow will create a reviewable report and will not automatically change or remove a canonical public record from a single unreviewed submission."
  />
</BaseLayout>
