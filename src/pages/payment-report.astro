---
import { ConfiguredReportForm } from '../components/submissions/ConfiguredReportForm';
import BaseLayout from '../layouts/BaseLayout.astro';
import { assetRegistry } from '../registries/assets';
import { networkRegistry } from '../registries/networks';

const assets = assetRegistry.map((asset) => ({
  value: asset.slug,
  label: `${asset.symbol} — ${asset.name}`,
}));
const networks = networkRegistry.map((network) => ({
  value: network.slug,
  label: network.name,
}));

const requestedTargetType = Astro.url.searchParams.get('targetType');
const initialTargetType =
  requestedTargetType === 'location' || requestedTargetType === 'claim'
    ? requestedTargetType
    : 'entity';
const initialTargetId = Astro.url.searchParams.get('targetId') ?? '';
---

<BaseLayout
  title="Report a payment result — CryptoPayMap"
  description="Submit a successful or failed crypto payment observation for private CryptoPayMap review."
>
  <header class="safe-area-inline page-container py-10 sm:py-14">
    <p class="m-0 text-sm font-semibold text-brand-700">Contribute</p>
    <h1 class="mt-2 max-w-3xl text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      Report a payment result
    </h1>
    <p class="mt-4 max-w-3xl text-base leading-7 text-muted">
      Tell CryptoPayMap whether a payment succeeded or failed, which asset and network were used, and what happened at checkout. The report remains private until reviewed.
    </p>
    <div class="mt-5 flex flex-wrap gap-3 text-sm">
      <a class="font-semibold text-brand-700" href="/report">Report incorrect information</a>
      <a class="font-semibold text-brand-700" href="/methodology">How verification works</a>
      <a class="font-semibold text-brand-700" href="/privacy">Privacy notice</a>
      <a class="font-semibold text-brand-700" href="/terms">Terms</a>
    </div>
  </header>

  <section class="safe-area-inline page-container pb-12 sm:pb-16">
    <div class="mx-auto max-w-4xl">
      <ConfiguredReportForm
        submissionType="payment_report"
        assets={assets}
        networks={networks}
        initialTargetType={initialTargetType}
        initialTargetId={initialTargetId}
        client:load
      />
    </div>
  </section>
</BaseLayout>
