---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  buildPublishedChangelogIndex,
  type PublicChangelogEntry,
} from '../public/release-surfaces';

const changelogEntries = await getCollection('changelog');
const publishedIndex = buildPublishedChangelogIndex(
  changelogEntries.map((entry) => ({
    id: entry.id,
    ...entry.data,
  })) as PublicChangelogEntry[],
);
const entryById = new Map(changelogEntries.map((entry) => [entry.id, entry]));
const releases = await Promise.all(
  publishedIndex.map(async (release) => {
    const entry = entryById.get(release.id);
    if (!entry) throw new Error(`Published Changelog entry is unavailable: ${release.id}`);
    return { release, Content: (await render(entry)).Content };
  }),
);
---

<BaseLayout title="Changelog · CryptoPayMap" description="Released CryptoPayMap changes.">
  <div class="safe-area-inline page-container py-12 sm:py-16 lg:py-20">
    <header class="max-w-3xl">
      <p class="m-0 text-sm font-semibold uppercase tracking-[0.12em] text-brand-700">
        Public Changelog
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-ink sm:text-5xl">
        Released product changes
      </h1>
      <p class="mt-5 text-lg leading-8 text-muted">
        This page records released product, policy, interface, security, and public data-contract
        changes. Individual acceptance-record changes are listed separately in Updates.
      </p>
    </header>

    {
      releases.length === 0 ? (
        <section class="mt-12 rounded-card border border-border bg-surface p-6 shadow-panel">
          <h2 class="m-0 text-xl font-semibold text-ink">No public release entries yet</h2>
          <p class="mt-3 text-base leading-7 text-muted">
            This page begins when a product release is made available to users. Draft release notes
            are never shown here.
          </p>
        </section>
      ) : (
        <div class="mt-12 grid gap-8">
          {releases.map(({ release, Content }) => (
            <article
              id={release.anchor}
              class="scroll-mt-6 rounded-card border border-border bg-surface p-6 shadow-panel"
            >
              <header class="border-b border-border pb-5">
                <p class="m-0 text-sm font-semibold text-brand-700">Version {release.version}</p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight text-ink">
                  {release.summary}
                </h2>
                <p class="mt-2 text-sm text-muted">Released {release.publishedAt}</p>
                <ul class="mt-4 flex flex-wrap gap-2" aria-label="Change categories">
                  {release.categories.map((category) => (
                    <li class="rounded-pill bg-canvas px-3 py-1 text-xs font-semibold text-muted">
                      {category}
                    </li>
                  ))}
                </ul>
              </header>
              <div class="pt-5 text-base leading-7 text-muted">
                <Content />
              </div>
            </article>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
