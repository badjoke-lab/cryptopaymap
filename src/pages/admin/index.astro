---
import { AdminDashboard } from '../../components/admin/AdminDashboard';
import AdminLayout from '../../layouts/AdminLayout.astro';

const sections = [
  {
    href: '/admin/candidates',
    title: 'Candidate review',
    description:
      'Inspect private source Candidates and provenance, resolve duplicates, then enter a separate promotion or existing-target workflow.',
  },
  {
    href: '/admin/claims',
    title: 'Claim workflows',
    description:
      'Route Claim creation, Evidence decisions, reconfirmation, and Audit inspection to their separate protected workspaces.',
  },
  {
    href: '/admin/evidence',
    title: 'Evidence',
    description:
      'Review exact Evidence and Claim versions, accepted Evidence sets, source strength, and contradictions before a supported decision.',
  },
  {
    href: '/admin/rechecks',
    title: 'Rechecks',
    description: 'Manage due, overdue, and stale Claim review through exact reconfirmation state.',
  },
  {
    href: '/admin/media',
    title: 'Media',
    description: 'Separate private proof, rights review, privacy checks, and public-gallery eligibility.',
  },
  {
    href: '/admin/exports',
    title: 'Exports',
    description:
      'Review validated private export candidates and durable release decisions before separate publication and restore boundaries.',
  },
  {
    href: '/admin/audit',
    title: 'Audit history',
    description:
      'Inspect normalized protected decision history across Candidate, canonical, Evidence, reconfirmation, Media, and export domains.',
  },
];
---

<AdminLayout
  title="Administration | CryptoPayMap"
  heading="Operations workspace"
  description="A protected dashboard for bounded operational summaries and explicit navigation into separate review, decision, correction, release, publication, restore, and Audit boundaries."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="access-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">Access boundary active</p>
    <h2 id="access-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Identity and dashboard capability are checked before private queries
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      The Pages Function verifies the Cloudflare Access assertion before the dashboard endpoint maps an exact subject identifier to the read-only dashboard capability. Missing configuration, denied identities, and invalid summaries fail closed.
    </p>
  </section>

  <section class="mt-8" aria-labelledby="operational-summary-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Operational overview</p>
        <h2 id="operational-summary-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
          Operational summary
        </h2>
      </div>
      <span class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
        Read-only bounded counts
      </span>
    </div>
    <AdminDashboard client:load />
  </section>

  <section class="mt-10" aria-labelledby="workspace-sections-title">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Protected operation map</p>
        <h2 id="workspace-sections-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
          Review and decision areas
        </h2>
      </div>
      <span class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
        Separate capability boundaries
      </span>
    </div>

    <div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {
        sections.map((section) => (
          <a
            class="motion-feedback group rounded-card border border-border bg-surface p-5 text-ink no-underline shadow-sm transition hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-panel"
            href={section.href}
          >
            <h3 class="m-0 text-lg font-semibold tracking-tight group-hover:text-brand-800">{section.title}</h3>
            <p class="mt-2 text-sm leading-6 text-muted">{section.description}</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Open section →</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-8 rounded-card border border-border bg-surface p-5 sm:p-6" aria-labelledby="safety-title">
    <h2 id="safety-title" class="m-0 text-xl font-semibold tracking-tight text-ink">Current safety state</h2>
    <ul class="mt-4 grid gap-3 text-sm leading-6 text-muted sm:grid-cols-2">
      <li>Dashboard access grants no write capability.</li>
      <li>Candidate promotion and existing-target linking use separate write capabilities and exact state guards.</li>
      <li>Correction, Evidence, reconfirmation, Media, release, publication, restore, and Audit remain separate protected boundaries.</li>
      <li>Private records are not embedded in static HTML.</li>
    </ul>
  </section>
</AdminLayout>
