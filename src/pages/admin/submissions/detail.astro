---
import { SubmissionReviewFollowupPanel } from '../../../components/admin/SubmissionReviewFollowupPanel';
import { SuggestAcceptedCandidatePanel } from '../../../components/admin/SuggestAcceptedCandidatePanel';
import { SuggestSubmissionReview } from '../../../components/admin/SuggestSubmissionReview';
import { SuggestReviewTransitionPanel } from '../../../components/admin/SuggestReviewTransitionPanel';
import AdminLayout from '../../../layouts/AdminLayout.astro';

const submissionId = Astro.url.searchParams.get('id');
---

<AdminLayout
  title="Suggest review | CryptoPayMap Admin"
  heading="Suggest review"
  description="Inspect the normalized Suggest proposal, review bounded overlap signals, apply exact-state workflow transitions, request bounded additional information, place review on a time-bounded Hold, resume review explicitly, or preserve a useful incomplete Suggest as a private Candidate."
>
  <section
    class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6"
    aria-labelledby="suggest-review-boundary-title"
  >
    <p class="m-0 text-sm font-semibold text-brand-800">Guarded reviewer workflow</p>
    <h2
      id="suggest-review-boundary-title"
      class="mt-1 text-xl font-semibold tracking-tight text-ink"
    >
      Read-only signals remain separate from exact-state workflow transitions
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      Zero signals are non-conclusive. Review entry, information requests, time-bounded Hold, explicit resume, and accepted-as-Candidate remain separate protected operations. None of them accepts Evidence, changes canonical records, exports, or publishes automatically.
    </p>
    <div class="mt-5">
      <a
        class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-brand-700 px-4 py-2 text-sm font-semibold text-brand-800 no-underline hover:bg-brand-100"
        href="/admin/submissions"
      >
        Return to Suggest queue
      </a>
    </div>
  </section>

  <section class="mt-8" aria-labelledby="suggest-review-actions-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Separate write capability</p>
        <h2
          id="suggest-review-actions-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Review entry
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        received → triage → in review
      </span>
    </div>
    <section class="rounded-card border border-border bg-surface p-5 shadow-sm">
      <SuggestReviewTransitionPanel client:load />
    </section>
  </section>

  <section class="mt-8" aria-labelledby="suggest-followup-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">P5-06C common boundary</p>
        <h2
          id="suggest-followup-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Information, Hold, and resume
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        Exact-state guarded
      </span>
    </div>
    <SubmissionReviewFollowupPanel sourceKind="suggest" submissionId={submissionId} client:load />
  </section>

  <section class="mt-8" aria-labelledby="suggest-candidate-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Private review-material outcome</p>
        <h2
          id="suggest-candidate-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Accept as private Candidate
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        No canonical or public mutation
      </span>
    </div>
    <section class="rounded-card border border-border bg-surface p-5 shadow-sm">
      <p class="mb-4 max-w-3xl text-sm leading-6 text-muted">
        Use this only when the normalized Suggest is useful review material but not sufficient canonical truth. The transaction creates a private source observation and Candidate, links them as origin material, and resolves the Submission as accepted as Candidate.
      </p>
      <SuggestAcceptedCandidatePanel client:load />
    </section>
  </section>

  <section class="mt-8" aria-labelledby="suggest-review-workspace-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Protected Submission detail</p>
        <h2
          id="suggest-review-workspace-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Reviewer workspace
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        Signals remain read-only
      </span>
    </div>
    <SuggestSubmissionReview client:load />
  </section>
</AdminLayout>
