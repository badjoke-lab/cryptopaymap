---
import { SuggestInformationRequestPanel } from '../../../components/admin/SuggestInformationRequestPanel';
import { SuggestSubmissionReview } from '../../../components/admin/SuggestSubmissionReview';
import { SuggestReviewTransitionPanel } from '../../../components/admin/SuggestReviewTransitionPanel';
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Suggest review | CryptoPayMap Admin"
  heading="Suggest review"
  description="Inspect the normalized Suggest proposal, review bounded overlap signals, apply exact-state workflow transitions, and request bounded additional information without crossing into duplicate, Candidate, canonical, Evidence, export, or publication mutations."
>
  <section
    class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6"
    aria-labelledby="suggest-review-boundary-title"
  >
    <p class="m-0 text-sm font-semibold text-brand-800">Guarded reviewer workflow</p>
    <h2
      id="suggest-review-boundary-title"
      class="mt-1 text-xl font-semibold tracking-tight text-ink"
    >
      Read-only signals remain separate from guarded workflow and information-request actions
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      Zero signals are non-conclusive. This phase allows received → triage, triage → in review, and an in-review information request. It does not mark duplicates, create Candidates, select canonical targets, accept Evidence, write canonical values, export, or publish.
    </p>
    <div class="mt-5">
      <a
        class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-brand-700 px-4 py-2 text-sm font-semibold text-brand-800 no-underline hover:bg-brand-100"
        href="/admin/submissions"
      >
        Return to Suggest queue
      </a>
    </div>
  </section>

  <section class="mt-8" aria-labelledby="suggest-review-actions-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Separate write capability</p>
        <h2
          id="suggest-review-actions-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Review workflow actions
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        Exact-state guarded
      </span>
    </div>
    <section class="rounded-card border border-border bg-surface p-5 shadow-sm">
      <SuggestReviewTransitionPanel client:load />
    </section>
  </section>

  <section class="mt-8" aria-labelledby="suggest-information-request-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Submitter follow-up boundary</p>
        <h2
          id="suggest-information-request-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Request additional information
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        in review → needs information
      </span>
    </div>
    <section class="rounded-card border border-border bg-surface p-5 shadow-sm">
      <p class="mb-4 max-w-3xl text-sm leading-6 text-muted">
        Only bounded requested-action text and a public status message are projected to the submitter. General reviewer notes and other private event material remain private.
      </p>
      <SuggestInformationRequestPanel client:load />
    </section>
  </section>

  <section class="mt-8" aria-labelledby="suggest-review-workspace-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Protected Submission detail</p>
        <h2
          id="suggest-review-workspace-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Reviewer workspace
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        Signals remain read-only
      </span>
    </div>
    <SuggestSubmissionReview client:load />
  </section>
</AdminLayout>
