---
import { PhotoSubmissionReview } from '../../../components/admin/PhotoSubmissionReview';
import AdminLayout from '../../../layouts/AdminLayout.astro';

const submissionId = Astro.url.searchParams.get('id');
---

<AdminLayout
  title="Photos parent review | CryptoPayMap Admin"
  heading="Photos parent Submission"
  description="A protected parent-Submission workspace for normalized public-gallery candidates and exact-state review entry. Private objects, contact values, status secrets, reviewer notes, Media approval, and publication remain outside this page."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="photo-review-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">P5-06B Photos review-entry boundary</p>
    <h2 id="photo-review-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Review the parent Submission before any Media decision or publication
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      This workspace exposes bounded normalized candidate summaries and allows only the parent workflow transitions from received to triage and triage to in review. It does not approve Media, copy objects to public storage, resolve the parent Submission, change canonical data, export, or publish.
    </p>
  </section>

  <section class="mt-8" aria-label="Protected Photos parent detail and review-entry controls">
    <PhotoSubmissionReview submissionId={submissionId} client:load />
  </section>
</AdminLayout>
