---
import { PhotoParentResolutionPanel } from '../../../components/admin/PhotoParentResolutionPanel';
import { PhotoSubmissionReview } from '../../../components/admin/PhotoSubmissionReview';
import { SubmissionReviewFollowupPanel } from '../../../components/admin/SubmissionReviewFollowupPanel';
import { SubmissionTerminalResolutionPanel } from '../../../components/admin/SubmissionTerminalResolutionPanel';
import AdminLayout from '../../../layouts/AdminLayout.astro';

const submissionId = Astro.url.searchParams.get('id');
---

<AdminLayout
  title="Photos parent review | CryptoPayMap Admin"
  heading="Photos parent Submission"
  description="A protected parent-Submission workspace for normalized public-gallery candidates, exact-state review entry, information requests, time-bounded Hold, explicit resume, common eligible closure, and the aggregate P5-06E outcome derived only from completed child Media decisions. Private objects, contact values, status secrets, reviewer notes, Media approval, and publication remain separate."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="photo-review-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">P5-06B through P5-06E Photos workflow boundary</p>
    <h2 id="photo-review-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Review child outcomes before resolving the parent Submission
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      Common terminal controls may mark an exact duplicate, no change, or withdrawal. P5-06E separately derives approved, partially approved, or not approved only after every Media item in the retained handoff has a durable initial decision. Nothing here makes a Media decision, copies objects to public storage, changes canonical data, exports, or publishes.
    </p>
  </section>

  <section class="mt-8" aria-label="Protected Photos parent detail and review-entry controls">
    <PhotoSubmissionReview submissionId={submissionId} client:load />
  </section>

  <section class="mt-8" aria-label="Protected Photos information Hold and resume controls">
    <SubmissionReviewFollowupPanel sourceKind="photos" submissionId={submissionId} client:load />
  </section>

  <section class="mt-8" aria-label="Protected Photos aggregate parent-resolution controls">
    <PhotoParentResolutionPanel submissionId={submissionId} client:load />
  </section>

  <section class="mt-8" aria-label="Protected Photos terminal-resolution controls">
    <SubmissionTerminalResolutionPanel sourceKind="photos" submissionId={submissionId} client:load />
  </section>
</AdminLayout>
