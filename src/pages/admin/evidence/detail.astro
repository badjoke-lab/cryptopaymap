---
import { EvidenceReviewDetail } from '../../../components/admin/EvidenceReviewDetail';
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Evidence decision | CryptoPayMap Admin"
  heading="Evidence decision"
  description="A protected workspace for one atomic Evidence review decision."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="evidence-decision-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">Decision boundary</p>
    <h2 id="evidence-decision-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Evidence, Claim, and accepted-set guards
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      The workspace fixes every reviewed version before commit and records the resulting Evidence disposition, optional Claim action, verification event, and replay receipt together.
    </p>
  </section>

  <section class="mt-8" aria-labelledby="evidence-detail-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">P3-08C</p>
        <h2 id="evidence-detail-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
          Evidence review workspace
        </h2>
      </div>
      <span class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
        Atomic decision
      </span>
    </div>
    <EvidenceReviewDetail client:load />
  </section>
</AdminLayout>
