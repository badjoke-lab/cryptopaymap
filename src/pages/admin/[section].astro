---
import AdminLayout from '../../layouts/AdminLayout.astro';

export function getStaticPaths() {
  return [
    {
      params: { section: 'submissions' },
      props: {
        heading: 'Submissions',
        description:
          'Public contribution review belongs to MVP-B and is intentionally not connected before the Phase 5 submission foundation exists.',
      },
    },
  ];
}

interface Props {
  heading: string;
  description: string;
}

const { heading, description } = Astro.props;
---

<AdminLayout title={`${heading} | CryptoPayMap Admin`} heading={heading} description={description}>
  <section class="rounded-card border border-border bg-surface p-6 shadow-sm" aria-labelledby="placeholder-title">
    <p class="m-0 text-sm font-semibold uppercase tracking-[0.1em] text-brand-700">Future protected boundary</p>
    <h2 id="placeholder-title" class="mt-2 text-xl font-semibold tracking-tight text-ink">
      No submission records or controls are connected
    </h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-muted">
      This route reserves the protected navigation boundary for Phase 5. Public submissions do not exist yet, and this page performs no private query or write operation.
    </p>
    <a
      class="motion-feedback mt-5 inline-flex min-h-11 items-center rounded-control bg-brand-600 px-4 py-2 font-semibold text-white no-underline hover:bg-brand-700"
      href="/admin"
    >
      Return to overview
    </a>
  </section>
</AdminLayout>
