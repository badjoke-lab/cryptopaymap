---
import { CandidateGroupNavigation } from '../../../components/admin/CandidateGroupNavigation';
import { ReviewCandidate } from '../../../components/admin/ReviewCandidate';
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Candidate detail | CryptoPayMap Admin"
  heading="Candidate detail"
  description="A protected workspace for Candidate source and provenance inspection. Duplicate review, new-target promotion, and existing-target linking remain separate guarded operations reached from the Candidate workflow."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="detail-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">Candidate inspection boundary</p>
    <h2 id="detail-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Known source payloads are revalidated before an allowlisted snapshot is shown
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      Unknown or malformed payloads remain hidden. Duplicate review uses bounded Candidate summaries and does not merge source rows. Canonical operations use separate version, source-set, provenance, and authorization boundaries.
    </p>
    <div class="mt-5">
      <CandidateGroupNavigation client:load />
    </div>
  </section>

  <section class="mt-8" aria-labelledby="candidate-detail-workspace-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">Candidate provenance</p>
        <h2 id="candidate-detail-workspace-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
          Provenance review
        </h2>
      </div>
      <span class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
        Protected inspection
      </span>
    </div>
    <ReviewCandidate client:load />
  </section>
</AdminLayout>
