---
import { CandidateExistingTargetEditor } from '../../../components/admin/CandidateExistingTargetEditor';
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Existing canonical target | CryptoPayMap Admin"
  heading="Link to existing canonical target"
  description="Search, compare, and explicitly select an existing canonical identity before creating a separate hidden candidate Claim."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="existing-target-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">Existing-target boundary</p>
    <h2 id="existing-target-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Reuse canonical identity without rewriting it
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      The selected Entity, optional Location, canonical path, and complete existing Claim set are version-pinned. Candidate sources are attached to selected identity fields as attribution, while the operation creates only a hidden candidate Claim and Claim Assets with origin provenance.
    </p>
  </section>

  <section class="mt-8" aria-labelledby="existing-target-workspace-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">P3-07I</p>
        <h2 id="existing-target-workspace-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
          Search and comparison workspace
        </h2>
      </div>
      <span class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
        Exact target snapshot
      </span>
    </div>
    <CandidateExistingTargetEditor client:load />
  </section>
</AdminLayout>
