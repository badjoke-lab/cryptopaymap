---
import { LocationCorrectionEditor } from '../../../components/admin/LocationCorrectionEditor';
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Location correction | CryptoPayMap Admin"
  heading="Location profile correction"
  description="A protected workspace for reviewed practical-profile corrections on an existing canonical Place."
>
  <section
    class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6"
    aria-labelledby="location-correction-boundary-title"
  >
    <p class="m-0 text-sm font-semibold text-brand-800">Correction boundary</p>
    <h2
      id="location-correction-boundary-title"
      class="mt-1 text-xl font-semibold tracking-tight text-ink"
    >
      Candidate source set, Location version, field diff, and correction provenance
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      This workspace applies reviewed practical-profile corrections to an existing canonical Location.
      It does not link the Candidate, change Claim verification state, or publish public artifacts.
    </p>
  </section>

  <section class="mt-8" aria-labelledby="location-correction-workspace-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">P4-18B4C</p>
        <h2
          id="location-correction-workspace-title"
          class="mt-1 text-2xl font-semibold tracking-tight text-ink"
        >
          Reviewed Location correction workspace
        </h2>
      </div>
      <span
        class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
      >
        Atomic correction
      </span>
    </div>
    <LocationCorrectionEditor client:load />
  </section>
</AdminLayout>
