---
import { SuggestSubmissionQueue } from '../../components/admin/SuggestSubmissionQueue';
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Submissions | CryptoPayMap Admin"
  heading="Submissions"
  description="A protected read-only entry point for Suggest review. The queue exposes bounded normalized summaries only; original payloads, contact data, secrets, and internal notes are not returned."
>
  <section class="rounded-card border border-brand-600 bg-brand-50 p-5 sm:p-6" aria-labelledby="submission-boundary-title">
    <p class="m-0 text-sm font-semibold text-brand-800">Submission review boundary</p>
    <h2 id="submission-boundary-title" class="mt-1 text-xl font-semibold tracking-tight text-ink">
      Review normalized proposals and bounded overlap signals before any decision or mutation
    </h2>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-muted">
      This workspace is read-only. Duplicate decisions, Candidate creation, canonical target selection, linking, Evidence acceptance, canonical transactions, exports, and publication remain separate guarded operations.
    </p>
  </section>

  <section class="mt-8" aria-labelledby="submission-queue-title">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="m-0 text-sm font-semibold text-brand-700">MVP-B intake</p>
        <h2 id="submission-queue-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
          Suggest review queue
        </h2>
      </div>
      <span class="rounded-pill border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
        Protected read-only
      </span>
    </div>
    <SuggestSubmissionQueue client:load />
  </section>
</AdminLayout>
