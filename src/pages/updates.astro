---
import { getCollection } from 'astro:content';
import UpdatesTimeline from '../components/public/UpdatesTimeline.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildPublicUpdatesViewModel, type PublicUpdate } from '../public/updates';

const entries = await getCollection('publicUpdates');
const updates = entries.map((entry) => (entry.data as { update: PublicUpdate }).update);
const model = buildPublicUpdatesViewModel(updates);
---

<BaseLayout
  title="Updates | CryptoPayMap"
  description="See newly confirmed, reconfirmed, changed, stale, and ended CryptoPayMap public acceptance records."
>
  <main class="safe-area-inline page-container py-8 sm:py-12 lg:py-16">
    <header class="max-w-3xl">
      <p class="m-0 text-sm font-semibold text-brand-700">Public record changes</p>
      <h1 class="mt-2 text-4xl font-semibold tracking-[-0.04em] text-ink sm:text-5xl">Updates</h1>
      <p class="mt-4 text-base leading-7 text-muted">
        Updates show changes to published acceptance records. Product and interface releases are recorded separately in the Changelog.
      </p>
    </header>

    {
      model.total === 0 ? (
        <section class="mt-10 rounded-card border border-border bg-surface p-6 shadow-sm sm:p-8">
          <h2 class="m-0 text-2xl font-semibold text-ink">No public record updates yet</h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-muted sm:text-base">
            This feed will show reviewed public changes after records are confirmed, reconfirmed, changed, marked stale, ended, or added as online services.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a
              class="motion-feedback inline-flex min-h-11 items-center rounded-control bg-brand-600 px-4 py-2 font-semibold text-white no-underline hover:bg-brand-700"
              href="/places"
            >
              Browse Places
            </a>
            <a
              class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-border px-4 py-2 font-semibold text-ink no-underline hover:bg-brand-50"
              href="/online"
            >
              Browse Online Services
            </a>
          </div>
        </section>
      ) : (
        <div class="mt-10">
          <div class="mb-6 flex flex-wrap items-center justify-between gap-3 border-b border-border pb-4 text-sm text-muted">
            <p class="m-0">
              <strong class="text-ink">{model.total}</strong> public record {model.total === 1 ? 'change' : 'changes'}
            </p>
            {model.latestEffectiveAt ? (
              <p class="m-0">
                Latest effective change:{' '}
                {new Intl.DateTimeFormat('en', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                  timeZone: 'UTC',
                }).format(new Date(model.latestEffectiveAt))}
              </p>
            ) : null}
          </div>
          <UpdatesTimeline groups={model.groups} />
        </div>
      )
    }
  </main>
</BaseLayout>
