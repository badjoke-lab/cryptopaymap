---
import { getCollection } from 'astro:content';
import { PlacesApp } from '../components/places/PlacesApp';
import BaseLayout from '../layouts/BaseLayout.astro';
import { publicPlacePinSchema, publicPlaceSchema } from '../schemas/public-exports';

const pinEntries = await getCollection('publicPlacePins');
const pins = pinEntries.map((entry) =>
  publicPlacePinSchema.parse((entry.data as { pin: unknown }).pin),
);
const placeEntries = await getCollection('publicPlaces');
const places = placeEntries.map((entry) =>
  publicPlaceSchema.parse((entry.data as { place: unknown }).place),
);
---

<BaseLayout
  title="Places | CryptoPayMap"
  description="Find reviewed physical places where cryptocurrency payment is accepted at checkout."
>
  <PlacesApp pins={pins} places={places} client:load />
</BaseLayout>
