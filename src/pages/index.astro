---
import { FoundationStatus } from '../components/FoundationStatus';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CryptoPayMap">
  <main>
    <header>
      <p>CryptoPayMap</p>
      <h1>Where crypto actually works at checkout.</h1>
      <p>
        A verified discovery service for physical places and online services where customers can pay from a cryptocurrency wallet.
      </p>
    </header>

    <FoundationStatus client:visible />

    <nav aria-label="Project documentation">
      <a href="https://github.com/badjoke-lab/cryptopaymap/blob/main/docs/PROJECT_STATUS.md">Project status</a>
      <a href="https://github.com/badjoke-lab/cryptopaymap/blob/main/docs/ROADMAP.md">Public roadmap</a>
    </nav>
  </main>
</BaseLayout>

<style>
  main {
    width: min(100% - 2rem, 72rem);
    margin-inline: auto;
    padding-block: clamp(3rem, 8vw, 7rem);
  }

  header {
    max-width: 48rem;
  }

  header > p:first-child {
    color: #0f766e;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin-block: 0.75rem 1rem;
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  header > p:last-child {
    max-width: 42rem;
    color: #475569;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
  }

  section {
    margin-top: 3rem;
    padding: 1.5rem;
    border: 1px solid #cbd5e1;
    border-radius: 0.75rem;
    background: #ffffff;
  }

  button {
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 0;
    border-radius: 0.625rem;
    background: #0f766e;
    color: white;
    cursor: pointer;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  nav a {
    color: #0f766e;
    font-weight: 600;
  }
</style>
