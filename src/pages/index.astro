---
import { getCollection } from 'astro:content';
import PublicHome from '../components/public/PublicHome.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildPublicHomeModel } from '../public/home';
import { publicOnlineServiceSchema, publicPlaceSchema } from '../schemas/public-exports';

const placeEntries = await getCollection('publicPlaces');
const serviceEntries = await getCollection('publicOnlineServices');
const roadmapEntries = await getCollection('roadmap');
const changelogEntries = await getCollection('changelog');

const places = placeEntries.map((entry) =>
  publicPlaceSchema.parse((entry.data as { place: unknown }).place),
);
const services = serviceEntries.map((entry) =>
  publicOnlineServiceSchema.parse((entry.data as { service: unknown }).service),
);
const model = buildPublicHomeModel(places, services);
const roadmapEntry = roadmapEntries
  .filter((entry) => entry.data.section === 'now')
  .sort((left, right) => left.data.order - right.data.order)[0];
const latestReleaseEntry = changelogEntries
  .filter((entry) => !entry.data.draft)
  .sort((left, right) => Date.parse(right.data.publishedAt) - Date.parse(left.data.publishedAt))[0];
const roadmap = roadmapEntry
  ? {
      title: roadmapEntry.data.title,
      outcome: roadmapEntry.data.outcome,
      status: roadmapEntry.data.status,
    }
  : null;
const latestRelease = latestReleaseEntry
  ? {
      version: latestReleaseEntry.data.version,
      summary: latestReleaseEntry.data.summary,
      publishedAt: latestReleaseEntry.data.publishedAt,
    }
  : null;
---

<BaseLayout
  title="CryptoPayMap"
  description="Find reviewed physical places and online services where cryptocurrency can be used at checkout."
>
  <PublicHome model={model} roadmap={roadmap} latestRelease={latestRelease} />
</BaseLayout>
