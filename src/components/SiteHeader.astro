---
const navigation = [
  { href: '/places', label: 'Places' },
  { href: '/online', label: 'Online Services' },
  { href: '/stats', label: 'Stats' },
  { href: '/updates', label: 'Updates' },
  { href: '/support', label: 'Support' },
];

const pathname = Astro.url.pathname;
---

<header class="relative z-50 border-b border-border bg-surface/95 backdrop-blur">
  <div class="safe-area-inline page-container flex min-h-14 items-center justify-between gap-3 py-2 md:min-h-16 md:gap-4 md:py-3">
    <a
      class="motion-feedback shrink-0 rounded-control font-semibold tracking-tight text-ink no-underline transition-colors hover:text-brand-700"
      href="/"
      aria-label="CryptoPayMap home"
    >
      <span class="text-brand-600">Crypto</span>PayMap
    </a>

    <nav class="hidden min-w-0 flex-1 md:block" aria-label="Primary">
      <ul class="flex min-w-max items-center justify-end gap-1">
        {
          navigation.map((item) => {
            const isActive = pathname === item.href || pathname.startsWith(`${item.href}/`);

            return (
              <li>
                <a
                  class:list={[
                    'motion-feedback inline-flex min-h-11 items-center rounded-control px-3 text-sm font-medium no-underline transition-colors',
                    isActive
                      ? 'bg-brand-50 text-brand-800'
                      : 'text-muted hover:bg-canvas hover:text-ink',
                  ]}
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <details class="group relative md:hidden">
      <summary class="motion-feedback flex min-h-11 cursor-pointer list-none items-center gap-2 rounded-control border border-border bg-surface px-3 text-sm font-semibold text-ink shadow-sm [&::-webkit-details-marker]:hidden">
        <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        Menu
      </summary>

      <nav
        class="absolute right-0 top-[calc(100%+0.5rem)] w-[min(18rem,calc(100vw-2rem))] rounded-card border border-border bg-surface p-2 shadow-panel"
        aria-label="Mobile primary"
      >
        <ul class="grid gap-1">
          {
            navigation.map((item) => {
              const isActive = pathname === item.href || pathname.startsWith(`${item.href}/`);

              return (
                <li>
                  <a
                    class:list={[
                      'motion-feedback flex min-h-11 items-center rounded-control px-3 py-2 text-sm font-medium no-underline transition-colors',
                      isActive
                        ? 'bg-brand-50 text-brand-800'
                        : 'text-muted hover:bg-canvas hover:text-ink',
                    ]}
                    href={item.href}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </details>
  </div>
</header>
