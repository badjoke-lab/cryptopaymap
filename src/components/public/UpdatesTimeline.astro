---
import type { PublicUpdateGroup } from '../../public/updates';

interface Props {
  groups: PublicUpdateGroup[];
}

const { groups } = Astro.props;

const labels = {
  newly_confirmed: 'Newly confirmed',
  reconfirmed: 'Reconfirmed',
  payment_method_changed: 'Payment method changed',
  marked_stale: 'Marked stale',
  ended: 'Ended',
  new_online_service: 'New online service',
} as const;

function formatDate(value: string): string {
  return new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(value));
}

function subjectHref(subjectType: 'place' | 'online_service', subjectSlug: string): string {
  return subjectType === 'place' ? `/place/${subjectSlug}` : `/service/${subjectSlug}`;
}
---

<div class="grid gap-10">
  {
    groups.map((group) => (
      <section aria-labelledby={`updates-${group.monthKey}`}>
        <div class="flex items-center gap-3">
          <h2
            id={`updates-${group.monthKey}`}
            class="m-0 text-2xl font-semibold tracking-tight text-ink"
          >
            {group.monthLabel}
          </h2>
          <span class="rounded-pill bg-brand-50 px-2.5 py-1 text-xs font-semibold text-brand-800">
            {group.updates.length}
          </span>
        </div>

        <ol class="mt-5 grid list-none gap-3 p-0">
          {group.updates.map((update) => (
            <li>
              <article class="rounded-card border border-border bg-surface p-4 shadow-sm sm:p-5">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded-pill bg-brand-50 px-2.5 py-1 text-xs font-semibold text-brand-800">
                    {labels[update.updateType]}
                  </span>
                  <time class="text-xs font-medium text-muted" datetime={update.effectiveAt}>
                    {formatDate(update.effectiveAt)}
                  </time>
                </div>

                <h3 class="mt-3 text-lg font-semibold text-ink sm:text-xl">
                  <a
                    class="rounded-control text-inherit no-underline transition-colors hover:text-brand-700"
                    href={subjectHref(update.subjectType, update.subjectSlug)}
                  >
                    {update.title}
                  </a>
                </h3>
                <p class="mt-2 max-w-3xl text-sm leading-6 text-muted sm:text-base">
                  {update.summary}
                </p>
                <a
                  class="mt-3 inline-flex min-h-11 items-center rounded-control font-semibold text-brand-700 underline-offset-4 hover:underline"
                  href={subjectHref(update.subjectType, update.subjectSlug)}
                >
                  View public record
                </a>
              </article>
            </li>
          ))}
        </ol>
      </section>
    ))
  }
</div>
