---
import type { OnlineServiceDetailModel } from '../../public/online-services';
import PublicMediaGallery from './PublicMediaGallery.astro';
import PublicMediaHero from './PublicMediaHero.astro';

interface Props {
  model: OnlineServiceDetailModel;
}

const { model } = Astro.props;
const { service, status, claims, cover, gallery } = model;
const formatLabel = (value: string) =>
  value
    .split('_')
    .map((part) => `${part.charAt(0).toUpperCase()}${part.slice(1)}`)
    .join(' ');
const formatDate = (value: string) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(value));
---

<article class="safe-area-inline page-container py-8 sm:py-12 lg:py-16">
  <nav class="text-sm text-muted" aria-label="Breadcrumb">
    <a class="font-medium text-brand-700 no-underline hover:underline" href="/online">Online Services</a>
    <span aria-hidden="true"> / </span>
    <span aria-current="page">{service.name}</span>
  </nav>

  <header class="mt-5 overflow-hidden rounded-card border border-border bg-surface shadow-panel">
    <PublicMediaHero cover={cover} placeholderLabel={formatLabel(service.categorySlug)} />
    <div class="p-5 sm:p-7">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-pill border border-border bg-canvas px-3 py-1 text-xs font-semibold text-muted">
          {formatLabel(status)}
        </span>
        <span class="text-sm font-medium text-muted">{formatLabel(service.categorySlug)}</span>
      </div>
      <div class="mt-3 grid gap-5 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start">
        <div>
          <h1 class="m-0 text-3xl font-semibold tracking-[-0.035em] text-ink sm:text-5xl">{service.name}</h1>
          <p class="mt-3 max-w-3xl text-base leading-7 text-muted">
            {service.countryCode ? `Region: ${service.countryCode}` : 'Global or service-defined availability'}
          </p>
        </div>
        <a class="motion-feedback inline-flex min-h-11 items-center justify-center rounded-control bg-brand-600 px-4 py-2 font-semibold text-white no-underline hover:bg-brand-700" href={service.websiteUrl} rel="external noopener">
          Open official website
        </a>
      </div>
    </div>
  </header>

  <section class="mt-8 rounded-card border border-border bg-surface p-5 shadow-sm sm:p-6" aria-labelledby="online-payment-summary-title">
    <p class="m-0 text-sm font-semibold text-brand-700">Payment summary</p>
    <h2 id="online-payment-summary-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">Checkout payment options</h2>
    <dl class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-control bg-canvas p-4"><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Assets</dt><dd class="mt-2 font-semibold text-ink">{model.assetSymbols.join(', ')}</dd></div>
      <div class="rounded-control bg-canvas p-4"><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Networks</dt><dd class="mt-2 font-semibold text-ink">{model.networkSlugs.map(formatLabel).join(', ')}</dd></div>
      <div class="rounded-control bg-canvas p-4"><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Availability</dt><dd class="mt-2 font-semibold text-ink">{model.acceptanceScopes.map(formatLabel).join(', ')}</dd></div>
      <div class="rounded-control bg-canvas p-4"><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Last confirmed</dt><dd class="mt-2 font-semibold text-ink">{formatDate(model.lastConfirmedAt)}</dd></div>
    </dl>
  </section>

  <section class="mt-8" aria-labelledby="online-claims-title">
    <p class="m-0 text-sm font-semibold text-brand-700">How to pay</p>
    <h2 id="online-claims-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">Verified checkout routes</h2>
    <div class="mt-5 grid gap-5">
      {claims.map((claim) => (
        <article class="rounded-card border border-border bg-surface p-5 shadow-sm sm:p-6">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div><p class="m-0 text-sm font-semibold text-brand-700">{formatLabel(claim.routeType)}</p><h3 class="mt-1 text-xl font-semibold text-ink">{claim.howToPay}</h3></div>
            <span class="rounded-pill border border-border bg-canvas px-3 py-1 text-xs font-semibold text-muted">{formatLabel(claim.status)}</span>
          </div>
          <dl class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Scope</dt><dd class="mt-1 text-sm font-medium text-ink">{formatLabel(claim.acceptanceScope)}</dd></div>
            <div><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Processor</dt><dd class="mt-1 text-sm font-medium text-ink">{claim.processorSlug ? formatLabel(claim.processorSlug) : 'Direct payment'}</dd></div>
            <div><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Merchant receives</dt><dd class="mt-1 text-sm font-medium text-ink">{formatLabel(claim.merchantReceives)}</dd></div>
            <div><dt class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">Last confirmed</dt><dd class="mt-1 text-sm font-medium text-ink">{formatDate(claim.lastConfirmedAt)}</dd></div>
          </dl>
          {claim.restrictions ? <p class="mt-5 rounded-control border border-border bg-canvas p-4 text-sm leading-6 text-ink">{claim.restrictions}</p> : null}
          <ul class="mt-5 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            {claim.paymentAssets.map((payment) => <li class="rounded-control border border-border p-3 text-sm"><strong>{payment.assetSymbol}</strong><span class="ml-2 text-muted">{formatLabel(payment.networkSlug)} · {formatLabel(payment.paymentMethod)}</span></li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <div class="mt-8">
    <PublicMediaGallery media={gallery} />
  </div>

  <section class="mt-8" aria-labelledby="online-evidence-title">
    <p class="m-0 text-sm font-semibold text-brand-700">Evidence</p>
    <h2 id="online-evidence-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">Why this listing is public</h2>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      {claims.flatMap((claim) => claim.evidence.map((evidence) => (
        <article class="rounded-card border border-border bg-surface p-5 shadow-sm">
          <p class="m-0 text-xs font-semibold uppercase tracking-[0.06em] text-muted">{formatLabel(evidence.evidenceClass)} · {formatLabel(evidence.kind)}</p>
          <p class="mt-3 text-sm leading-6 text-ink">{evidence.summary}</p>
          <div class="mt-4 flex gap-3">{evidence.sourceUrl ? <a class="font-semibold text-brand-700" href={evidence.sourceUrl} rel="external noopener">Source</a> : null}{evidence.archiveUrl ? <a class="font-semibold text-brand-700" href={evidence.archiveUrl} rel="external noopener">Archive</a> : null}</div>
        </article>
      ))) }
    </div>
  </section>

  <div class="mt-8 flex flex-wrap gap-3 border-t border-border pt-6">
    <a class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-border px-4 py-2 font-semibold text-ink no-underline hover:bg-brand-50" href="/payment-report">I paid here</a>
    <a class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-border px-4 py-2 font-semibold text-ink no-underline hover:bg-brand-50" href="/report">Report a problem</a>
    <a class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-border px-4 py-2 font-semibold text-ink no-underline hover:bg-brand-50" href="/claim">Claim this service</a>
  </div>
</article>
