---
---

<section class="safe-area-inline border-b border-border bg-surface">
  <div class="page-container grid gap-10 py-12 sm:py-16 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-center lg:py-24">
    <div class="max-w-3xl">
      <p class="m-0 text-sm font-semibold uppercase tracking-[0.12em] text-brand-700">CryptoPayMap</p>
      <h1 class="mt-4 text-4xl font-semibold leading-[0.98] tracking-[-0.045em] text-ink sm:text-6xl lg:text-7xl">
        Where crypto actually works at checkout.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
        Find reviewed physical places and online services with explicit assets, networks, payment routes, instructions, evidence, and confirmation dates.
      </p>

      <form class="mt-8 flex max-w-2xl flex-col gap-2 sm:flex-row" action="/places" method="get">
        <label class="sr-only" for="home-place-search">Search verified places</label>
        <input
          id="home-place-search"
          class="min-h-12 min-w-0 flex-1 rounded-control border border-border bg-surface px-4 text-ink shadow-sm"
          type="search"
          name="q"
          placeholder="Search a place, city, category, or country"
        />
        <button
          class="motion-feedback min-h-12 rounded-control bg-brand-600 px-5 py-2.5 font-semibold text-white hover:bg-brand-700"
          type="submit"
        >
          Search places
        </button>
      </form>

      <div class="mt-4 flex flex-wrap gap-3">
        <a
          class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-border bg-surface px-4 py-2 font-semibold text-ink no-underline hover:bg-brand-50"
          href="/places"
        >
          Open the map
        </a>
        <a
          class="motion-feedback inline-flex min-h-11 items-center rounded-control border border-border bg-surface px-4 py-2 font-semibold text-ink no-underline hover:bg-brand-50"
          href="/online"
        >
          Browse Online Services
        </a>
      </div>
    </div>

    <aside
      class="rounded-card border border-border bg-brand-50 p-5 shadow-panel sm:p-6"
      aria-labelledby="home-verification-title"
    >
      <p class="m-0 text-sm font-semibold text-brand-700">Why this map is different</p>
      <h2 id="home-verification-title" class="mt-1 text-2xl font-semibold tracking-tight text-ink">
        Public records are reviewed first
      </h2>
      <p class="mt-3 text-sm leading-6 text-muted">
        Unverified source candidates stay private. Public records include payment context, evidence, and freshness so a listing is more than a pin on a map.
      </p>
      <a class="mt-4 inline-flex min-h-11 items-center font-semibold text-brand-700" href="/methodology">
        Read the methodology
      </a>
    </aside>
  </div>
</section>
