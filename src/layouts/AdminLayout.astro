---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  heading: string;
  description: string;
}

const { title, heading, description } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/admin';
const navigation = [
  { href: '/admin', label: 'Overview' },
  { href: '/admin/candidates', label: 'Candidates' },
  { href: '/admin/claims', label: 'Claims' },
  { href: '/admin/evidence', label: 'Evidence' },
  { href: '/admin/rechecks', label: 'Rechecks' },
  { href: '/admin/submissions', label: 'Submissions' },
  { href: '/admin/media', label: 'Media' },
  { href: '/admin/exports', label: 'Exports' },
  { href: '/admin/audit', label: 'Audit' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="no-referrer" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
  </head>
  <body class="min-h-screen bg-canvas text-ink">
    <a class="skip-link" href="#admin-main">Skip to administration content</a>

    <header class="border-b border-border bg-ink text-white">
      <div class="safe-area-inline page-container flex min-h-16 items-center justify-between gap-4 py-3">
        <a
          class="motion-feedback rounded-control font-semibold tracking-tight text-white no-underline transition-opacity hover:opacity-80"
          href="/admin"
          aria-label="CryptoPayMap administration home"
        >
          <span class="text-brand-50">Crypto</span>PayMap <span class="text-sm font-medium text-slate-300">Admin</span>
        </a>
        <div class="flex items-center gap-3">
          <span class="rounded-pill border border-slate-600 px-3 py-1 text-xs font-semibold uppercase tracking-[0.08em] text-slate-200">
            Protected workspace
          </span>
          <a
            class="motion-feedback inline-flex min-h-11 items-center rounded-control px-3 text-sm font-medium text-slate-200 no-underline hover:bg-slate-800 hover:text-white"
            href="/"
          >
            Public site
          </a>
        </div>
      </div>
    </header>

    <div class="safe-area-inline page-container grid min-h-[calc(100vh-4rem)] gap-0 lg:grid-cols-[15rem_minmax(0,1fr)]">
      <aside class="border-b border-border bg-surface py-3 lg:border-b-0 lg:border-r lg:py-6" aria-label="Administration sections">
        <nav class="overflow-x-auto lg:pr-5">
          <ul class="flex min-w-max gap-1 lg:grid lg:min-w-0">
            {
              navigation.map((item) => {
                const isActive = pathname === item.href;
                return (
                  <li>
                    <a
                      class:list={[
                        'motion-feedback inline-flex min-h-11 w-full items-center rounded-control px-3 py-2 text-sm font-medium no-underline transition-colors',
                        isActive
                          ? 'bg-brand-50 text-brand-800'
                          : 'text-muted hover:bg-canvas hover:text-ink',
                      ]}
                      href={item.href}
                      aria-current={isActive ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </aside>

      <main id="admin-main" class="min-w-0 px-0 py-8 lg:px-8 lg:py-10" tabindex="-1">
        <div class="max-w-6xl">
          <p class="m-0 text-sm font-semibold uppercase tracking-[0.1em] text-brand-700">Administration</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{heading}</h1>
          <p class="mt-3 max-w-3xl text-base leading-7 text-muted">{description}</p>

          <div class="mt-8">
            <slot />
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
