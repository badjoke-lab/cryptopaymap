---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Verified cryptocurrency payment discovery for physical places and online services.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f766e" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
